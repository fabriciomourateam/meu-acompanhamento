<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Capability de Push Notifications (APNs). 'development' vale pra debug;
	     no archive de distribuição (TestFlight/App Store) o Xcode/assinatura
	     promove pra 'production' automaticamente. -->
	<key>aps-environment</key>
	<string>development</string>
</dict>
</plist>
